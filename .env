# ── Database ──────────────────────────────────────────────────
DB_NAME=teambuilder
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# Повний рядок підключення — збирається з полів вище
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Для Alembic (синхронний драйвер)
SYNC_DATABASE_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── App ───────────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173

# ── Export ────────────────────────────────────────────────────
# Директорія для тимчасових PDF-файлів
EXPORT_DIR=/tmp/teambuilder_exports
